{
  "aliases": {
    "builder": "buildx"
  },
  "auths": {},
  "credsStore": "desktop",
  "currentContext": "default",
  "detachKeys": "ctrl-p,ctrl-q",
  "experimental": "enabled",
  "features": {
    "buildkit": "true"
  },
  "insecure-registries": ["192.168.1.137:8080"],
  "plugins": {
    "debug": {
      "hooks": "exec"
    }
  },
  "proxies": {
    "default": {
      "httpProxy": "",
      "httpsProxy": "",
      "noProxy": "localhost,127.0.0.1,.local"
    }
  },
  "psFormat": "table {{.ID}}\\t{{.Image}}\\t{{.Status}}\\t{{.Names}}"
}